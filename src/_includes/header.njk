<header class="site">
  <div class="nav-row">
    <a class="brand" href="/index.html">
      <img src="/assets/logo-peru.png" alt="IAEG Peru logo">
      <span class="brand-text">{{ site.name }}<span>{{ site.tagline }}</span></span>
    </a>
    <div class="nav-right">
      <a class="intl-link" href="https://iaeg.info" target="_blank" rel="noopener" title="International Association for Engineering Geology and the Environment">
        <img src="/logo-iaeg.png" alt="IAEG International logo">
        <span>IAEG International</span>
      </a>
      <button class="nav-toggle" aria-label="Toggle menu" onclick="document.querySelector('nav.primary').classList.toggle('open')">&#9776;</button>
      <nav class="primary">
        <ul>
          {% for item in site.menu %}
            {% if item.children %}
              <!-- Si el elemento tiene subpáginas (como About Us) -->
              <li class="dropdown">
                <a href="{{ item.url }}" class="dropdown-toggle {% if item.url == page.url %}active{% endif %}">
                  {{ item.name }} ▾
                </a>
                <ul class="dropdown-menu">
                  {% for child in item.children %}
                    <li><a href="{{ child.url }}">{{ child.name }}</a></li>
                  {% endfor %}
                </ul>
              </li>
            {% else %}
              <!-- Si es un botón normal del menú -->
              <li><a href="{{ item.url }}"{% if item.url == page.url %} class="active"{% endif %}>{{ item.name }}</a></li>
            {% endif %}
          {% endfor %}
        </ul>
      </nav>
    </div>
  </div>
</header>
