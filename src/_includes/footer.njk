<footer class="site">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <h4>{{ site.name }}</h4>
        <p style="color:var(--stone);opacity:.85;max-width:38ch;">{{ site.description }}</p>

        {% if site.socialLinks %}
        <div class="footer-social">
          {% for social in site.socialLinks %}
            {% if social.url %}
            <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ social.platform }}" class="footer-social-link">
              {% if social.platform == "Facebook" %}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7.5h2.5l.4-3H13.5V8.4c0-.87.24-1.46 1.5-1.46h1.6V4.35C16.3 4.24 15.3 4.15 14.16 4.15c-2.4 0-4.05 1.47-4.05 4.16v2.34H7.6v3h2.5V21z"/></svg>
              {% elif social.platform == "Instagram" %}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.97.24 2.43.4.6.24 1.03.51 1.48.96.45.45.72.88.96 1.48.16.46.35 1.26.4 2.43.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.24 1.97-.4 2.43-.24.6-.51 1.03-.96 1.48-.45.45-.88.72-1.48.96-.46.16-1.26.35-2.43.4-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.97-.24-2.43-.4a4 4 0 01-1.48-.96 4 4 0 01-.96-1.48c-.16-.46-.35-1.26-.4-2.43C2.01 15.58 2 15.2 2 12s.01-3.58.07-4.85c.05-1.17.24-1.97.4-2.43.24-.6.51-1.03.96-1.48.45-.45.88-.72 1.48-.96.46-.16 1.26-.35 2.43-.4C8.42 2.21 8.8 2.2 12 2.2zm0 1.98c-3.14 0-3.5.01-4.74.07-.96.04-1.48.2-1.82.34-.46.18-.79.39-1.13.74-.35.34-.56.67-.74 1.13-.14.34-.3.86-.34 1.82-.06 1.24-.07 1.6-.07 4.74s.01 3.5.07 4.74c.04.96.2 1.48.34 1.82.18.46.39.79.74 1.13.34.35.67.56 1.13.74.34.14.86.3 1.82.34 1.24.06 1.6.07 4.74.07s3.5-.01 4.74-.07c.96-.04 1.48-.2 1.82-.34.46-.18.79-.39 1.13-.74.35-.34.56-.67.74-1.13.14-.34.3-.86.34-1.82.06-1.24.07-1.6.07-4.74s-.01-3.5-.07-4.74c-.04-.96-.2-1.48-.34-1.82a3 3 0 00-.74-1.13 3 3 0 00-1.13-.74c-.34-.14-.86-.3-1.82-.34C15.5 4.19 15.14 4.18 12 4.18zm0 3.38a4.44 4.44 0 110 8.88 4.44 4.44 0 010-8.88zm0 1.98a2.46 2.46 0 100 4.92 2.46 2.46 0 000-4.92zm5.65-2.2a1.04 1.04 0 11-2.08 0 1.04 1.04 0 012.08 0z"/></svg>
              {% elif social.platform == "X" %}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M18.9 2H22l-7.5 8.6L23.3 22h-6.9l-5.4-7-6.2 7H1.6l8-9.2L1 2h7l4.9 6.4L18.9 2zm-1.2 18h1.9L7.4 4H5.4l12.3 16z"/></svg>
              {% elif social.platform == "LinkedIn" %}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5 2.5 2.5 0 01.02-5zM3 9h4v12H3zM9.5 9H13v1.7h.05c.5-.9 1.7-1.9 3.5-1.9 3.7 0 4.4 2.4 4.4 5.6V21h-4v-5.2c0-1.24-.02-2.83-1.73-2.83-1.73 0-2 1.35-2 2.75V21h-4z"/></svg>
              {% elif social.platform == "YouTube" %}
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.6 3.5 12 3.5 12 3.5s-7.6 0-9.4.6A3 3 0 00.5 6.2 31 31 0 000 12a31 31 0 00.5 5.8 3 3 0 002.1 2.1c1.8.6 9.4.6 9.4.6s7.6 0 9.4-.6a3 3 0 002.1-2.1A31 31 0 0024 12a31 31 0 00-.5-5.8zM9.6 15.5V8.5l6.4 3.5z"/></svg>
              {% endif %}
            </a>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
      </div>
      <div>
        <h4>Explore</h4>
        <ul>
          <li><a href="/about.html">About Us</a></li>
          <li><a href="/projects.html">Projects</a></li>
          <li><a href="/committees.html">Committees</a></li>
        </ul>
      </div>
      <div>
        <h4>Connect</h4>
        <ul>
          <li><a href="/partners.html">Partners</a></li>
          <li><a href="/news.html">News</a></li>
          <li><a href="/events.html">Events</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>{{ site.copyrightText }}</span>
      <span>{{ site.footerDomainLabel }}</span>
    </div>
  </div>
</footer>
